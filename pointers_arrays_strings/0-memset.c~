#include "main.h"

/**
 * _memset: memory with a constant byte.
 * @s: memory area s
 * @b: bytes
 * @n: iteration
 *
 * Return: a pointer to the memory area s
 */

char *_memset(char *s, char b, unsigned int n)
{
	unsigned int counter;

	for (counter = 0; counter < n ; counter++)
	{
		s[counter] = b;
	}
	return (s);
}
