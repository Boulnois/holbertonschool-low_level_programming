/**
 * _reverse_array - reverses the content of an array of integers
 * @a: an array of integers
 * @n: the number of elements to swap
 *
 * Return: countain element inverse
 */

void reverse_array(int *a, int n)
{
	int i;
	int tmp;

	for(i = 0; i < n ; i++)
	{
		tmp = a[i];
		a[i] = a[n];
		a[n] =tmp;
		n--;
	}
}
