#include <stdio.h>
#include "function_pointers.h"

/**
 * void print_name - prints a name as is
 * @name: name of the person
 * @f: function pointers
 * Return: return a function that prints a name.
 */

void print_name(char *name, void (*f)(char *))
{
	if (name != NULL && f != NULL)
	{
		f(name);
	}
}
