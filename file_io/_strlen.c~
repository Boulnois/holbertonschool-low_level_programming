#include <stdio.h>
#include <stdlib.h>
#include "main.h"

/**
 * _strlen - Calculates the length of a string.
 * @s: Pointer to the string to measure.
 *
 * Return: The number of characters in the string, excluding the null byte.
 */
int _strlen(char *s)
{
    int len = 0;

    while (s[len] != '\0')
        len++;
    return (len);
}
