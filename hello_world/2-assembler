#!/bin/bash
# Vérification de la variable CFILE
if [ -z "$CFILE" ]; then
    echo "Error: CFILE is not set."
    exit 1
fi

# Vérification de l'existence du fichier
if [ ! -f "$CFILE" ]; then
    echo "Error: $CFILE does not exist."
    exit 1
fi

# Génération du code d'assemblage
gcc -S "$CFILE" && echo "Assembly code generated as ${CFILE%.c}.s" || echo "Failed to generate assembly code."
