#!/bin/bash
[ -z "$CFILE" ] && echo "Erreur: La variable \$CFILE n'est pas définie." && exit 1; [ ! -f "$CFILE" ] && echo "Erreur: Le fichier C '$CFILE' n'existe pas." && exit 1; gcc -S "$CFILE" -o "${CFILE%.c}.s" && echo "Code assembleur généré avec succès dans '${CFILE%.c}.s'." || echo "Erreur lors de la génération du code assembleur. Vérifiez les erreurs de compilation dans '$CFILE'."
