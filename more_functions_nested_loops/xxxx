#include "main.h"

/**
    * more_numbers - Print 10 times the numbers from 0 to 14.
*/


void more_numbers(void)
{
        int number = 0;
        int line = 0;

        for (line = 0 ; line <= 9 ; line ++)
        {
                for ( ; number <= 14 ; number ++)
                {
                        if (number > 9)
                        _putchar(number / 10 + '0');

                _putchar(number % 10 + '0');
                }

        _putchar('\n');
        number = 0;
        }
}
