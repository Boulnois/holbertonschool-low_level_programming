#include "main.h"

/**
 * print_diagonal - function that draws a diagonal line on the terminal.
 * @n: the int for the paramaters of my function
 * Return: 0
 */

void print_diagonal(int n)
{
	int diago = 0;
	int negatif = 0;

	if (diago > 0)
	{
		for ( ; diago < negatif ; diago++)
		{
			for (negatif = 0 ; negatif < diago ; negatif++)
			{
				_putchar(' ');
			}
			negatif = 0;
			_putchar('\\');
			_putchar('\n');
		}
	}
	else
	_putchar('\n');
}
