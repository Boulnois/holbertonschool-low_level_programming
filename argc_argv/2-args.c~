#include <stdio.h>
/**
 * main - a program that prints all arguments it receive
 * @argc: number of arguments
 * @argv: arrays of arguments
 * Return: return only zero
 */

int main(int argc, char *argv[])
{
	int i;

        for (i = 0; i < argc; i++)
	{
		printf("%s\n", argv[i]);
	}
	return (0);
}
